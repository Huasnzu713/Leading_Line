<?xml version="1.0"?>
<!--
  mini_akm_robot.urdf — 阿克曼 4WD mini 车体
  移植自 turn_on_wheeltec_robot/urdf/mini_akm_robot.urdf（原文件已删）。
  增加了 gyro_link / imu_link / front_axle_link 三个 fixed 框架。
-->
<robot name="mini_akm_robot">

  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0.08 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.23 0.11 0.05"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.08 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.23 0.11 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.08 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.06"/>
    </inertial>
  </link>

  <!-- 4 个轮子（连续关节，纯视觉；转向在 MCU 内部做） -->
  <joint name="left_wheel_joint" type="continuous">
    <origin xyz="0 0.08 0.0325" rpy="1.57 0 0"/>
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="0 -0.08 0.0325" rpy="1.57 0 0"/>
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="left_front_joint" type="continuous">
    <origin xyz="0.14 0.08 0.0325" rpy="1.57 0 0"/>
    <parent link="base_link"/>
    <child link="left_front_link"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="left_front_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_front_joint" type="continuous">
    <origin xyz="0.14 -0.08 0.0325" rpy="1.57 0 0"/>
    <parent link="base_link"/>
    <child link="right_front_link"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="right_front_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- IMU / 陀螺仪 link（zonesion 4WD 无 IMU，留作占位） -->
  <joint name="base_link_to_gyro" type="fixed">
    <parent link="base_link"/>
    <child link="gyro_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>
  <link name="gyro_link"/>

  <joint name="gyro_to_imu" type="fixed">
    <parent link="gyro_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>

  <!-- 前桥占位 link（阿克曼转向几何中心；仅 TF，不动） -->
  <joint name="base_link_to_front_axle" type="fixed">
    <parent link="base_link"/>
    <child link="front_axle_link"/>
    <origin xyz="0.14 0 0.0325" rpy="0 0 0"/>
  </joint>
  <link name="front_axle_link"/>

  <!-- 超声框架（与原 leading_line_with_car.launch 静态 TF 对齐） -->
  <joint name="base_link_to_sonar1" type="fixed">
    <parent link="base_link"/>
    <child link="sonar1"/>
    <origin xyz="0.15 0.1 0.07" rpy="0 0 0"/>
  </joint>
  <link name="sonar1"/>

  <joint name="base_link_to_sonar2" type="fixed">
    <parent link="base_link"/>
    <child link="sonar2"/>
    <origin xyz="-0.15 0 0.03" rpy="3.1415926 0 0"/>
  </joint>
  <link name="sonar2"/>

  <joint name="base_link_to_laser1" type="fixed">
    <parent link="base_link"/>
    <child link="laser1"/>
    <origin xyz="0.15 -0.1 0.07" rpy="0 0 0"/>
  </joint>
  <link name="laser1"/>
</robot>
