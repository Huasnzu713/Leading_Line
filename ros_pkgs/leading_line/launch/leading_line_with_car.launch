<launch>
  <!-- 公共参数 -->
  <arg name="use_realsense"  default="true"
       doc="是否启动 RealSense（true → /camera/color/image_raw）"/>
  <arg name="image_topic"    default="/camera/color/image_raw"
       doc="图像话题（与摄像头一致）"/>
  <arg name="default_mode"   default="blue_path"
       doc="引导线模式：blue_path / green_path / test"/>
  <arg name="wheelbase_m"    default="0.30"  doc="等效阿克曼轴距（米），steer→angular.z 用"/>
  <arg name="max_speed"      default="0.30"  doc="最大线速度（m/s）"/>
  <arg name="min_speed"      default="0.05"  doc="最低有效速度"/>
  <arg name="publish_hz"     default="30.0"  doc="/cmd_vel 上限频率"/>
  <arg name="sonar_stop_m"   default="0.30"  doc="紧急停车距离（米），小于 0 禁用"/>
  <arg name="image_timeout_s" default="1.0"  doc="摄像头断流多久停车（秒）"/>

  <!-- 1) xcar 底盘：直接启动移植过来的 xcar_ros.py
       （订阅 /cmd_vel，把 (linear.x, linear.y, angular.z) 打包成
        zonesion 私有协议，通过 /dev/ttyXCar 串口发给小车 MCU）-->
  <node name="xcar_ros" pkg="leading_line" type="xcar/xcar_ros.py"
        output="screen" respawn="true"/>

  <!-- 2) xcar 静态 TF（base_link → sonar1/2/laser1），从原 mbot launch 搬过来 -->
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_sonar1"
        args="0.15 0.1 0.07 0 0 0 /base_link /sonar1 50" />
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_sonar2"
        args="-0.15 0 0.03 3.1415926 0 0 /base_link /sonar2 50" />
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_laser1"
        args="0.15 -0.1 0.07 0 0 0 /base_link /laser1 50" />

  <!-- 3) 摄像头：realsense2_camera 是 apt 包，$(find) 找得到就启
       （如果不用 realsense，user 自行启动 usb_cam 等）-->
  <group if="$(arg use_realsense)">
    <include file="$(find realsense2_camera)/launch/includes/nodelet.launch.xml">
      <arg name="tf_prefix"        value="camera"/>
      <arg name="camera"           value="camera"/>
      <arg name="enable_color"     value="true"/>
      <arg name="color_width"      value="640"/>
      <arg name="color_height"     value="480"/>
      <arg name="color_fps"        value="30"/>
      <arg name="enable_depth"     value="false"/>
      <arg name="enable_infra1"    value="false"/>
      <arg name="enable_infra2"    value="false"/>
      <arg name="enable_fisheye"   value="false"/>
      <arg name="enable_pointcloud" value="false"/>
      <arg name="align_depth"      value="true"/>
    </include>
    <node pkg="tf" type="static_transform_publisher" name="base_link_to_camera"
          args="0.1 0 0 0 0 0 base_link camera_link 50" />
  </group>

  <!-- 4) leading_line 节点 -->
  <include file="$(find leading_line)/launch/leading_line.launch">
    <arg name="image_topic"     value="$(arg image_topic)"/>
    <arg name="default_mode"    value="$(arg default_mode)"/>
    <arg name="wheelbase_m"     value="$(arg wheelbase_m)"/>
    <arg name="max_speed"       value="$(arg max_speed)"/>
    <arg name="min_speed"       value="$(arg min_speed)"/>
    <arg name="publish_hz"      value="$(arg publish_hz)"/>
    <arg name="sonar_stop_m"    value="$(arg sonar_stop_m)"/>
    <arg name="image_timeout_s" value="$(arg image_timeout_s)"/>
  </include>
</launch>