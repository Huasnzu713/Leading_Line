<launch>
  <arg name="use_realsense" default="true"/>
  <arg name="image_topic"   default="/camera/color/image_raw"/>
  <arg name="default_mode"  default="blue_path"/>
  <arg name="wheelbase_m"   default="0.30"/>
  <arg name="max_speed"     default="0.30"/>
  <arg name="min_speed"     default="0.05"/>
  <arg name="publish_hz"    default="30.0"/>
  <arg name="sonar_stop_m"  default="0.30"/>
  <arg name="image_timeout_s" default="1.0"/>

  <!-- xcar + 摄像头 + leading_line -->
  <include file="$(find leading_line)/launch/leading_line_with_car.launch">
    <arg name="use_realsense"   value="$(arg use_realsense)"/>
    <arg name="image_topic"     value="$(arg image_topic)"/>
    <arg name="default_mode"    value="$(arg default_mode)"/>
    <arg name="wheelbase_m"     value="$(arg wheelbase_m)"/>
    <arg name="max_speed"       value="$(arg max_speed)"/>
    <arg name="min_speed"       value="$(arg min_speed)"/>
    <arg name="publish_hz"      value="$(arg publish_hz)"/>
    <arg name="sonar_stop_m"    value="$(arg sonar_stop_m)"/>
    <arg name="image_timeout_s" value="$(arg image_timeout_s)"/>
  </include>

  <!-- 键盘遥控：直接启动我们移植的 mbot_teleop.py -->
  <node name="mbot_teleop" pkg="leading_line" type="xcar/mbot_teleop.py"
        output="screen">
    <param name="scale_linear"  value="0.1" type="double"/>
    <param name="scale_angular" value="0.4" type="double"/>
  </node>
</launch>