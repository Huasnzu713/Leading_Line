<launch>
  <!--
    仅启动 leading_line 节点。
    假设外部已经启动了：
      - 摄像头驱动（发布到 /usb_cam/image_raw 或对应的话题）
      - 底盘驱动（订阅 /cmd_vel，比如 turn_on_wheeltec_robot 的 wheeltec_robot 节点）

    用法::
      roslaunch leading_line leading_line.launch
      roslaunch leading_line leading_line.launch image_topic:=/camera/rgb/image_raw
      roslaunch leading_line leading_line.launch default_mode:=green_path
  -->

  <!-- 节点参数（可被命令行 <arg> 覆盖）-->
  <arg name="config_path"    default="$(env ROS_HOME)/../src/leading_line/jetson/config.yaml"
       doc="算法配置 YAML 路径"/>
  <arg name="image_topic"    default="/usb_cam/image_raw"
       doc="输入摄像头话题"/>
  <arg name="cmd_vel_topic"  default="/cmd_vel"
       doc="输出阿克曼 /cmd_vel"/>
  <arg name="wheelbase_m"    default="0.30"  doc="阿克曼轴距（米）"/>
  <arg name="max_speed"      default="0.30"  doc="最大线速度（m/s）"/>
  <arg name="min_speed"      default="0.05"  doc="最低有效速度"/>
  <arg name="publish_hz"     default="30.0"  doc="/cmd_vel 发布上限频率"/>
  <arg name="default_mode"   default="blue_path"
       doc="启动模式：blue_path / green_path / test"/>
  <arg name="image_timeout_s" default="1.0"  doc="摄像头断流多久停车"/>

  <rosparam command="load" file="$(find leading_line)/config/params.yaml"
            ns="leading_line"/>

  <node pkg="leading_line" type="leading_line_node.py" name="leading_line"
        output="screen" respawn="false">
    <param name="config_path"     value="$(arg config_path)"/>
    <param name="image_topic"     value="$(arg image_topic)"/>
    <param name="cmd_vel_topic"   value="$(arg cmd_vel_topic)"/>
    <param name="wheelbase_m"     value="$(arg wheelbase_m)"/>
    <param name="max_speed"       value="$(arg max_speed)"/>
    <param name="min_speed"       value="$(arg min_speed)"/>
    <param name="publish_hz"      value="$(arg publish_hz)"/>
    <param name="default_mode"    value="$(arg default_mode)"/>
    <param name="image_timeout_s" value="$(arg image_timeout_s)"/>
  </node>
</launch>
